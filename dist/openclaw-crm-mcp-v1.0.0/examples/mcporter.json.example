{
  "name": "openclaw-crm",
  "version": "1.0.0",
  "transport": "http",
  "cwd": "/root/.openclaw/workspace/mcp/current/openclaw-crm",
  "start_command": "bash -lc 'set -a && source ./.env && set +a && ./.venv/bin/python openclaw_crm_server.py run'",
  "mcp_url": "http://127.0.0.1:5001/mcp",
  "health_url": "http://127.0.0.1:5001/health",
  "headers": {
    "Authorization": "Bearer ${MCP_BEARER_TOKEN}"
  }
}
